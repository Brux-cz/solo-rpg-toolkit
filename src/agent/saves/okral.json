      {
        "type": "fate",
        "question": "Je to jeden ze zmizených sběračů z Ořechové Tvrze?",
        "oddsLabel": "50/50",
        "d100": 85,
        "yes": false,
        "exceptional": false,
        "randomEvent": false,
        "cf": 6,
        "threshold": 65,
